# Copy to .env and fill in real values before running docker compose.
# Generate AIRFLOW_FERNET_KEY with:
#   python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

CLIENT_ID=your_fuel_finder_client_id
CLIENT_SECRET=your_fuel_finder_client_secret
AIRFLOW_FERNET_KEY=your_generated_fernet_key
